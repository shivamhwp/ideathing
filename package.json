{
  "name": "ideathing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun vite dev --port 3000",
    "dev:web": "concurrently -k --prefix name --names convex,web \"bunx convex dev\" \"bun run dev\"",
    "build": "bun run --bun vite build",
    "preview": "bun run --bun vite preview",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore",
    "format:check": "oxfmt --check --ignore-path .gitignore --ignore-path .oxfmtignore",
    "check": "bun run lint && bun run format:check",
    "type-check": "bun run tsgo --noEmit"
  },
  "dependencies": {
